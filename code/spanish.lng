tooltip_explain_status = - = Estado desconocido (sin resultado aún)\nOK = Resultado válido\nDNS = No tomó la salida\nCancelado = Inscripción cancelada (aparece en lista salidas)\nMP = Falta picada\nDNF = No terminó\nDISQ = Descalificado\nOMT = Tiempo máximo superado\nOOC = Fuera de competición\nNTP = No participa
trea = tercera
tredje = tercera
