prefsVacantPosition = Posición de las vacantes
prefsWideSplitFormat = Imprimir parciales en formato ancho
prefsYouthAge = Edad mínima
prefsYouthFee = Precio reducido
prefsaddressxpos = Coordenada X de la dirección
prefsaddressypos = Coordenada Y de la dirección
prefsclasslimit = Limitar resultados mostrados por categoría
prefsintertime = Mostrar tiempos intermedios
prefspagebreak = Añadir saltos de página
prefsshowheader = Mostrar encabezados de página
prefssplitanalysis = Realizar análisis de parciales
